# WISDO Major Product Pass V5
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Discord bot and OAuth
DISCORD_TOKEN=
CLIENT_ID=
CLIENT_SECRET=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GUILD_ID=
CULTURE_COIN_ROLE_ID=
COACH_ROLE_ID=
OWNER_USER_ID=

# Session, credentials, broker webhooks, and cron security
# Generate long random values for production. ENCRYPTION_KEY must be 32+ chars.
SESSION_SECRET=replace-with-a-long-random-session-secret
ENCRYPTION_KEY=replace-with-at-least-32-random-characters
BROKER_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
CRON_SECRET=replace-with-a-long-random-cron-secret
DISCORD_COMMAND_API_SECRET=

# Persistence. Render blueprint mounts /var/data and uses /var/data/wisdo.
WISDO_PERSISTENCE_MODE=json
WISDO_STORAGE_PATH=./data/operator-desks
DATA_DIR=./data/operator-desks
DATABASE_URL=
WISDO_DB_SSL=false

# MT4 Reporter bridge
MT4_SYNC_PATH=/mt4-sync
MT4_SYNC_API_KEY=
MT4_PAIRING_CODE_TTL_HOURS=24
MT4_REQUIRE_KNOWN_PAIRING=true
MT4_MAX_PAYLOAD_KB=256

# Symbol matching safety gates
WISDO_SYMBOL_AUTOMATCH_ENABLED=true
WISDO_SYMBOL_SPIN_WHEEL_ENABLED=true
WISDO_SYMBOL_AUTOMATCH_EXECUTION_ENABLED=false

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_PATH=/stripe/webhook
STRIPE_SUCCESS_PATH=/checkout/success
STRIPE_CANCEL_PATH=/checkout/cancel
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_FUTURES=

# Email and market/AI providers
RESEND_API_KEY=
RESEND_FROM_EMAIL=
FINNHUB_API_KEY=
TRADING_ECONOMICS_API_KEY=
FIRECRAWL_API_KEY=
OPENAI_API_KEY=
WISDO_AI_MODEL=gpt-4.1-mini
# Saved TradingView layout where the private DF Sauce indicator is installed.
WISDO_DF_SAUCE_TRADINGVIEW_URL=
GOOGLE_AI_API_KEY=

# Push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@wisdo.app

# Affiliate activation
WISDO_ACTIVATION_FEE_AMOUNT=125
WISDO_AFFILIATE_DEFAULT_PERCENT=30
WISDO_AFFILIATE_MIN_PAYOUT=25
WISDO_AFFILIATE_HOLD_DAYS=7
WISDO_AFFILIATE_AUTO_APPROVE=false
WISDO_AFFILIATE_ALLOW_SELF_REFERRAL=false
WISDO_AFFILIATE_CLAWBACK_REFUNDS=true

# Signal grid and Discord notifications
SIGNAL_CHANNEL_ID=
TRADE_SIGNAL_CHANNEL_ID=
SIGNAL_BUTTON_TTL_SECONDS=180
WISDO_SIGNALS_FROM_ALL_CONNECTED=true
DISCORD_NOTIFICATION_WEBHOOK_URL=
WISDO_NOTIFICATION_WEBHOOK_URL=
WISDO_WIN_GIF_URLS=

# WISDO safety defaults
WISDO_ENABLED=true
WISDO_TONE=old_head_wizard
WISDO_MAX_SAFE_OPEN_TRADES=5
WISDO_DRAWDOWN_WARN_PERCENT=10
WISDO_DRAWDOWN_DANGER_PERCENT=20
WISDO_PROFIT_PROTECT_PERCENT=5
WISDO_MT4_STALE_MINUTES=5
WISDO_ENABLE_STRONG_WARNINGS=true

# Bot library
BOT_STORE_ENABLED=true
BOT_DELIVERY_DIR=./data/operator-desks/bot-deliveries
BOT_SOURCE_DIRS=./private-downloads/mt4-bots;./mql4
BOT_AUTO_SYNC_ON_START=true
