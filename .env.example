# WISDO v7.0.5 deserializer-safe MT4 transport and durable recognition environment example
# Never commit real secrets. Configure them in Render Environment.

NODE_ENV=production
PUBLIC_BASE_URL=https://wisdo-mt4-api-bridge.onrender.com

# Discord application and guild
DISCORD_TOKEN=
CLIENT_ID=
CLIENT_SECRET=
GUILD_ID=
CULTURE_COIN_ROLE_ID=
COACH_ROLE_ID=
OWNER_USER_ID=
AUTO_REGISTER_COMMANDS_ON_START=true
CREATE_PRIVATE_VOICE_CHANNELS=false
OPERATOR_DESK_CATEGORY_NAME=🔒 CULTURE COIN OPERATOR DESKS
OPERATOR_DESK_ARCHIVE_CATEGORY_NAME=📦 CULTURE COIN ARCHIVED DESKS

# Authoritative MT4 Reporter bridge
MT4_SYNC_PATH=/mt4-sync
MT4_SYNC_API_KEY=
# Optional comma-separated keys kept temporarily while older Reporters are updated.
MT4_SYNC_PREVIOUS_API_KEYS=
# Stable secret so pairing codes survive API-key rotation. Set once and do not rotate casually.
MT4_PAIRING_SIGNING_SECRET=
# Signed/known pairing codes may authenticate old Reporters whose API key is stale.
MT4_ALLOW_PAIRING_CODE_AUTH=true
MT4_REQUIRE_KNOWN_PAIRING=true
MT4_PAIRING_CODE_TTL_HOURS=24
MT4_MAX_PAYLOAD_KB=256
ENABLE_LEGACY_DEADSHOT_MT4_SYNC=false

# Durable production state
DATABASE_URL=
WISDO_PERSISTENCE_MODE=postgres
WISDO_DB_SSL=true
DB_POOL_MAX=2
WISDO_DB_QUERY_TIMEOUT_MS=5000
WISDO_DB_STATEMENT_TIMEOUT_MS=4000
WISDO_DB_FAIL_OPEN_READS=true
WISDO_DB_BUFFER_LIVE_WRITES=true

# Optional Redis command transport (PostgreSQL remains required)
REDIS_ENABLED=false
REDIS_URL=
REDIS_PREFIX=wisdo

# Session/security
SESSION_SECRET=
ENCRYPTION_KEY=
BROKER_WEBHOOK_SECRET=
CRON_SECRET=

# Optional notifications and OAuth providers
RESEND_API_KEY=
RESEND_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bounded copier/signal worker prevents large snapshots from blocking /mt4-sync.
WISDO_SIGNAL_BACKGROUND_CONCURRENCY=2
WISDO_SIGNAL_TASK_TIMEOUT_MS=15000
WISDO_PAIRING_CACHE_TTL_MS=300000
# Server pressure controls
WISDO_JSON_BODY_LIMIT=4mb
WISDO_COMPRESSION_THRESHOLD_BYTES=1024
WISDO_SLOW_REQUEST_MS=2500
WISDO_SIGNAL_BACKGROUND_MAX_QUEUE=150
# Heap-safe Reporter poll and command-state controls
WISDO_MT4_ACTIVE_COMMAND_LIMIT=500
WISDO_MT4_ACTIVE_PER_USER_LIMIT=300
WISDO_MT4_ACTIVE_PER_ACCOUNT_LIMIT=125
WISDO_MT4_CRITICAL_COMMAND_LIMIT=200
WISDO_MT4_COMMAND_SCAN_LIMIT=3000
WISDO_MT4_COMMAND_HISTORY_LIMIT=150
WISDO_MT4_COMMAND_AUDIT_LIMIT=150
WISDO_MT4_DELIVERY_ID_CACHE_MS=300000
WISDO_MT4_DELIVERY_CACHE_MAX=500
WISDO_MT4_RATE_LIMIT_CACHE_MAX=750
WISDO_PAIRING_CACHE_MAX=750
WISDO_PAIRING_RECOVERY_MAX=150
WISDO_REPORTER_HEARTBEAT_INTERVAL_MS=15000
WISDO_REPORTER_HEARTBEAT_CACHE_MAX=500
WISDO_MT4_POLL_AFTER_MS=2000
WISDO_MT4_POLL_BURST_MS=750
WISDO_MT4_POLL_CACHE_MAX=750
WISDO_MT4_COMMAND_RESPONSE_MAX_BYTES=16384
# Canonical copy-command namespace. Prevents offline followers from retaining unlimited work.
WISDO_COPY_COMMAND_ACTIVE_LIMIT=250
WISDO_COPY_COMMAND_PER_USER_LIMIT=100
WISDO_COPY_COMMAND_PER_ACCOUNT_LIMIT=75
WISDO_COPY_COMMAND_CRITICAL_LIMIT=100
WISDO_COPY_COMMAND_SCAN_LIMIT=2000
WISDO_COPY_COMMAND_HISTORY_LIMIT=100
WISDO_COPY_SIGNAL_HISTORY_LIMIT=300
WISDO_COPY_AUDIT_LIMIT=300
WISDO_COPY_TRADE_LOG_LIMIT=300
WISDO_COPY_TICKET_ACCOUNT_LIMIT=250
WISDO_COPY_TICKET_PER_ACCOUNT_LIMIT=500
WISDO_ACCOUNT_CACHE_MAX_USERS=250
WISDO_FUNNEL_RATE_CACHE_MAX=500
WISDO_DISCORD_GRID_TIMER_MAX=100
WISDO_RANK_PROCESS_MIN_INTERVAL_MS=10000
WISDO_RANK_PROCESS_CACHE_MAX=500
WISDO_MEMORY_SHED_RATIO=0.70
# Set this to the actual memory allowance of the Render service.
WISDO_RENDER_MEMORY_LIMIT_MB=512
WISDO_MT4_HISTORY_GLOBAL_LIMIT=200
WISDO_MT4_HISTORY_ACCOUNT_LIMIT=40
WISDO_SIGNAL_HISTORY_LIMIT=200

WISDO_DURABLE_MUTATION_TIMEOUT_MS=12000
WISDO_ACCOUNT_SYNC_FLIGHT_MAX=250
WISDO_LEDGER_SYNC_FLIGHT_MAX=250
WISDO_COACH_FLIGHT_MAX=150
