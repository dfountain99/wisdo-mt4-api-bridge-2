# WISDO Major Product Pass V5
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Discord bot and OAuth
DISCORD_TOKEN=
CLIENT_ID=
CLIENT_SECRET=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GUILD_ID=
CULTURE_COIN_ROLE_ID=
COACH_ROLE_ID=
OWNER_USER_ID=

# Session, credentials, broker webhooks, and cron security
# Generate long random values for production. ENCRYPTION_KEY must be 32+ chars.
SESSION_SECRET=replace-with-a-long-random-session-secret
ENCRYPTION_KEY=replace-with-at-least-32-random-characters
BROKER_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
CRON_SECRET=replace-with-a-long-random-cron-secret
DISCORD_COMMAND_API_SECRET=

# Persistence. Render blueprint mounts /var/data and uses /var/data/wisdo.
WISDO_PERSISTENCE_MODE=json
WISDO_STORAGE_PATH=./data/operator-desks
DATA_DIR=./data/operator-desks
DATABASE_URL=
WISDO_DB_SSL=false

# MT4 Reporter bridge
MT4_SYNC_PATH=/mt4-sync
MT4_SYNC_API_KEY=
MT4_PAIRING_CODE_TTL_HOURS=24
MT4_REQUIRE_KNOWN_PAIRING=true
MT4_MAX_PAYLOAD_KB=256

# Symbol matching safety gates
WISDO_SYMBOL_AUTOMATCH_ENABLED=true
WISDO_SYMBOL_SPIN_WHEEL_ENABLED=true
WISDO_SYMBOL_AUTOMATCH_EXECUTION_ENABLED=false

# Square hosted checkout
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_API_VERSION=2026-05-20
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_PATH=/api/public/webhooks/square
# Must exactly match the public webhook URL registered in Square.
SQUARE_WEBHOOK_NOTIFICATION_URL=
SQUARE_SUCCESS_PATH=/checkout/success
SQUARE_CANCEL_PATH=/checkout/cancel
# Square Catalog subscription plan variation IDs for each WISDO billing cycle.
SQUARE_SUBSCRIPTION_PLAN_ID=
SQUARE_SUBSCRIPTION_PLAN_MONTHLY_ID=
SQUARE_SUBSCRIPTION_PLAN_QUARTERLY_ID=
SQUARE_SUBSCRIPTION_PLAN_SEMIANNUAL_ID=
SQUARE_SUBSCRIPTION_PLAN_ANNUAL_ID=

# Email and market/AI providers
RESEND_API_KEY=
RESEND_FROM_EMAIL=
FINNHUB_API_KEY=
TRADING_ECONOMICS_API_KEY=
FIRECRAWL_API_KEY=
OPENAI_API_KEY=
WISDO_AI_MODEL=gpt-4.1-mini
# Saved TradingView layout where the private DF Sauce indicator is installed.
WISDO_DF_SAUCE_TRADINGVIEW_URL=
# Optional external MP4 renderer. The browser-narrated AI Webinar Room works without it.
WISDO_AI_VIDEO_PROVIDER_URL=
WISDO_AI_VIDEO_PROVIDER_KEY=
WISDO_AI_VIDEO_WEBHOOK_SECRET=
GOOGLE_AI_API_KEY=

# Real historical OHLC data for Study Room chart examples.
# WISDO refuses to generate substitute/fake candles when no provider is ready.
WISDO_HISTORICAL_DATA_PROVIDER=auto
TWELVE_DATA_API_KEY=
WISDO_MARKET_DATA_URL=
WISDO_MARKET_DATA_TOKEN=
WISDO_MARKET_DATA_TIMEOUT_MS=12000

# Push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@wisdo.app

# Affiliate activation
WISDO_ACTIVATION_FEE_AMOUNT=125
WISDO_AFFILIATE_DEFAULT_PERCENT=30
WISDO_AFFILIATE_MIN_PAYOUT=25
WISDO_AFFILIATE_HOLD_DAYS=7
WISDO_AFFILIATE_AUTO_APPROVE=false
WISDO_AFFILIATE_ALLOW_SELF_REFERRAL=false
WISDO_AFFILIATE_CLAWBACK_REFUNDS=true

# Signal grid and Discord notifications
SIGNAL_CHANNEL_ID=
TRADE_SIGNAL_CHANNEL_ID=
SIGNAL_BUTTON_TTL_SECONDS=180
WISDO_SIGNALS_FROM_ALL_CONNECTED=true
DISCORD_NOTIFICATION_WEBHOOK_URL=
WISDO_NOTIFICATION_WEBHOOK_URL=
WISDO_WIN_GIF_URLS=

# WISDO safety defaults
WISDO_ENABLED=true
WISDO_TONE=old_head_wizard
WISDO_MAX_SAFE_OPEN_TRADES=5
WISDO_DRAWDOWN_WARN_PERCENT=10
WISDO_DRAWDOWN_DANGER_PERCENT=20
WISDO_PROFIT_PROTECT_PERCENT=5
WISDO_MT4_STALE_MINUTES=5
WISDO_ENABLE_STRONG_WARNINGS=true

# Bot library
BOT_STORE_ENABLED=true
BOT_DELIVERY_DIR=./data/operator-desks/bot-deliveries
BOT_SOURCE_DIRS=./private-downloads/mt4-bots;./mql4
BOT_AUTO_SYNC_ON_START=true

# Transactional signup email and consent-based SMS
WISDO_EMAIL_REPLY_TO=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Growth funnel targets (targets are measured, not guaranteed)
FUNNEL_MONTHLY_LEAD_TARGET=1000
FUNNEL_TARGET_CONVERSION_RATE=20

# Signed personal learning rooms + consent-based education sequence
WISDO_LEAD_PORTAL_SECRET=
WISDO_LEAD_PORTAL_TTL_DAYS=30
# Leave 0 for the production 1/3/5/7-day sequence. Set a positive minute value only for testing.
WISDO_FUNNEL_SEQUENCE_STEP_MINUTES=0

# Render memory safety and bounded Reporter persistence
WISDO_MT4_HISTORY_GLOBAL_LIMIT=500
WISDO_MT4_HISTORY_ACCOUNT_LIMIT=100
WISDO_MT4_SIGNAL_TRACKING_ACCOUNT_LIMIT=250
WISDO_SIGNAL_HISTORY_LIMIT=500

# Coalesce near-simultaneous duplicate Reporter snapshots instead of returning HTTP 429
WISDO_MT4_SYNC_MIN_INTERVAL_MS=750
