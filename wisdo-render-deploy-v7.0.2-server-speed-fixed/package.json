{
  "name": "culture-coin-operator-desks-bot",
  "version": "7.0.2",
  "description": "WISDO v7.0 Living Operating System: Nexus briefing, missions, workspaces, timeline, automation studio, Culture Score, AI memory, device hub, and ecosystem map.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "register-commands": "node scripts/registerCommands.js",
    "start:web": "node scripts/startWebOnly.js",
    "dev:web": "node --watch scripts/startWebOnly.js",
    "test": "node --test tests/*.test.js",
