  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "discord.js": "^14.27.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "redis": "^5.8.2",
    "web-push": "^3.6.7"
  },
  "overrides": {
    "ws": "8.21.1"
  }
}
