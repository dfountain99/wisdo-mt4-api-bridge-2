{
  "name": "culture-coin-operator-desks-bot",
  "version": "6.3.0",
  "description": "WISDO v6.3.0 Presence Awareness: identity-aware greetings, workspace memory, device/session awareness, account context, mode controls, and portal-wide presence telemetry.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "register-commands": "node scripts/registerCommands.js",
    "start:web": "node scripts/startWebOnly.js",
    "dev:web": "node --watch scripts/startWebOnly.js",
    "test": "node --test tests/*.test.js",
    "check": "node scripts/checkBuild.js && npm test",
    "migrate:postgres": "node scripts/migratePostgres.js"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "discord.js": "^14.26.5",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "redis": "^5.8.2",
    "web-push": "^3.6.7"
  }
}
