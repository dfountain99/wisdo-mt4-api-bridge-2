# WISDO v7.0.1 production environment example
# Never commit real secrets. Configure them in Render Environment.

NODE_ENV=production
PUBLIC_BASE_URL=https://wisdo-mt4-api-bridge.onrender.com

# Discord application and guild
DISCORD_TOKEN=
CLIENT_ID=
CLIENT_SECRET=
GUILD_ID=
CULTURE_COIN_ROLE_ID=
COACH_ROLE_ID=
OWNER_USER_ID=
AUTO_REGISTER_COMMANDS_ON_START=true
CREATE_PRIVATE_VOICE_CHANNELS=false
OPERATOR_DESK_CATEGORY_NAME=🔒 CULTURE COIN OPERATOR DESKS
OPERATOR_DESK_ARCHIVE_CATEGORY_NAME=📦 CULTURE COIN ARCHIVED DESKS

# Authoritative MT4 Reporter bridge
MT4_SYNC_PATH=/mt4-sync
MT4_SYNC_API_KEY=
MT4_REQUIRE_KNOWN_PAIRING=true
MT4_PAIRING_CODE_TTL_HOURS=24
MT4_MAX_PAYLOAD_KB=256
ENABLE_LEGACY_DEADSHOT_MT4_SYNC=false

# Durable production state
DATABASE_URL=
WISDO_PERSISTENCE_MODE=postgres
WISDO_DB_SSL=true
DB_POOL_MAX=4
WISDO_DB_QUERY_TIMEOUT_MS=5000
WISDO_DB_STATEMENT_TIMEOUT_MS=4000
WISDO_DB_FAIL_OPEN_READS=true
WISDO_DB_BUFFER_LIVE_WRITES=true

# Optional Redis command transport (PostgreSQL remains required)
REDIS_ENABLED=false
REDIS_URL=
REDIS_PREFIX=wisdo

# Session/security
SESSION_SECRET=
ENCRYPTION_KEY=
BROKER_WEBHOOK_SECRET=
CRON_SECRET=

# Optional notifications and OAuth providers
RESEND_API_KEY=
RESEND_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
